DATABASE_URL="postgresql://postgres:postgres@localhost:5432/patient_management?schema=public"
JWT_SECRET="change-me-to-a-long-random-secret"
PORT=4000

# Frontend URL used inside password-reset emails
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
APP_URL="http://localhost:5173"

# Comma-separated browser origins allowed to call this API
# Local: http://localhost:5173,http://127.0.0.1:5173
# Production: https://your-app.vercel.app
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"

# SMTP (example: Gmail with App Password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your.email@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM="Patient Chart <your.email@gmail.com>"
